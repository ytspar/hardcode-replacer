{
  "name": "hardcode-replacer",
  "version": "2.1.1",
  "description": "CLI tool for finding hardcoded colors, Tailwind classes, and extractable patterns in codebases",
  "main": "src/cli.js",
  "bin": {
    "hardcode-replacer": "./bin/hardcode-replacer.js"
  },
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": "./src/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ytspar/hardcode-replacer.git"
  },
  "scripts": {
    "start": "node bin/hardcode-replacer.js",
    "site": "npm --prefix site run dev",
    "site:build": "npm --prefix site run build",
    "site:preview": "npm --prefix site run preview",
    "test": "jest",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "keywords": [
    "css",
    "tailwind",
    "colors",
    "refactoring",
    "hardcoded",
    "design-tokens"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "jest": "^29.7.0",
    "ultracite": "^7.2.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
