{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/biome/core"],
  "overrides": [
    {
      "includes": ["test/**"],
      "formatter": { "enabled": false },
      "linter": {
        "rules": {
          "correctness": {
            "noGlobalDirnameFilename": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          }
        }
      }
    }
  ]
}
